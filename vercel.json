{
    "version": 2,
    "framework": null,
    "buildCommand": null,
    "installCommand": null,
    "outputDirectory": "public",
    "functions": {
        "api/index.php": {
           "runtime": "vercel-php@0.9.0"
        }
    },
    "routes": [
        {
            "src": "/favicon.ico",
            "dest": "/public/favicon.ico"
        },
        {
            "src": "/robots.txt",
            "dest": "/public/robots.txt"
        },
        {
            "src": "/(css|js|images|fonts)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_NAME": "EduVance Portal",
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "APP_KEY": "base64:MXd/WMrjwHc+g/cQ7aZFL5hk4V3Ml/NnpkDJHjtSDh4=",
        "APP_URL": "",
        "DB_CONNECTION": "sqlite",
        "SESSION_DRIVER": "cookie",
        "CACHE_STORE": "array",
        "QUEUE_CONNECTION": "sync",
        "LOG_CHANNEL": "stderr",
        "VERCEL": "1"
    }
}
